# Copy to .env and fill in real values. .env is gitignored — never commit it.
# Every variable the code reads should appear here with a safe placeholder.

# dev | prod — selects conf/config.<env>.yaml overrides
ENVIRONMENT=dev

# --- Database secrets ---
# Nested with __ to map onto Settings (WAREHOUSE__PASSWORD -> warehouse password).
# Non-secret host/port/driver/user live in conf/databases.yaml.
WAREHOUSE__PASSWORD=changeme

# --- External API ---
API_TOKEN=changeme
